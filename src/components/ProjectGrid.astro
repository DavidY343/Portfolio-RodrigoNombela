---
import { fetchBehanceProjects } from '../services/behance';
import ProjectCard from './ProjectCard.astro';

const projects = await fetchBehanceProjects();
---

<section class="max-w-7xl mx-auto px-6 py-20">
    <div class="flex items-center justify-between mb-12">
        <h2 class="text-3xl font-bold font-serif tracking-tight">Proyectos Recientes</h2>
        <div class="h-px flex-1 mx-8 bg-gradient-to-r from-accent/50 to-transparent"></div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.length > 0 ? (
            projects.map((project) => (
                <ProjectCard 
                    title={project.title} 
                    thumbnail={project.thumbnail} 
                    link={project.link} 
                    images={project.images}
                />
            ))
        ) : (
            <div class="col-span-full py-20 text-center glass rounded-2xl">
                <p class="text-gray-400">No se pudieron cargar los proyectos de Behance. Por favor, inténtalo más tarde.</p>
            </div>
        )}
    </div>
</section>
