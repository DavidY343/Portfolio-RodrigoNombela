---
import Layout from '../layouts/Layout.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import VideoModal from '../components/VideoModal.astro';
---

<Layout title="Rodrigo Nombela | Realizador Audiovisual">
	<main>
		<!-- Hero Section -->
		<section class="min-h-screen flex flex-col items-center justify-center text-center px-6 relative overflow-hidden">
			<div class="absolute top-1/4 left-1/4 w-96 h-96 bg-accent/20 rounded-full blur-[120px] -z-10 animate-pulse"></div>
			<div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-blue-600/10 rounded-full blur-[120px] -z-10"></div>
			
			<div class="relative mb-8 group">
				<div class="absolute -inset-1 bg-gradient-to-r from-accent to-blue-600 rounded-full blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
				<img 
					src={import.meta.env.BASE_URL + "rodrifoto.png"} 
					alt="Rodrigo Nombela" 
					class="relative w-32 h-32 md:w-40 md:h-40 rounded-full object-cover border-2 border-white/10 shadow-2xl"
				/>
			</div>

			<h1 class="text-6xl md:text-8xl font-serif font-light tracking-tighter mb-6 bg-gradient-to-b from-white to-white/40 bg-clip-text text-transparent">
				RODRIGO NOMBELA
			</h1>
			<p class="text-xl md:text-2xl text-gray-400 font-light tracking-widest uppercase mb-12">
				Realizador Audiovisual & Narrador Visual
			</p>
			
			<div class="flex gap-6">
				<a href="#proyectos" class="px-8 py-3 bg-white text-black font-bold rounded-full hover:bg-accent hover:text-white transition-all duration-300">
					Ver Trabajo
				</a>
				<a href="mailto:rodrigodomnguez6@gmail.com" class="px-8 py-3 glass text-white font-bold rounded-full hover:bg-white/10 transition-all duration-300">
					Contacto
				</a>
			</div>
			
			<div class="absolute bottom-10 animate-bounce">
				<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
				</svg>
			</div>
		</section>

		<div id="proyectos">
			<ProjectGrid />
		</div>

		<VideoModal />
		
		<footer class="py-20 text-center border-t border-white/5 mt-20">
			<p class="text-gray-500 text-sm tracking-widest uppercase">
				&copy; {new Date().getFullYear()} Rodrigo Nombela. Todos los derechos reservados.
			</p>
			<div class="mt-6 flex justify-center gap-8 text-gray-400">
				<a href="https://www.behance.net/rodrigodomnguez6" target="_blank" class="hover:text-white transition-colors">Behance</a>
				<a href="#" target="_blank" class="hover:text-white transition-colors">Vimeo</a>
				<a href="#" target="_blank" class="hover:text-white transition-colors">Instagram</a>
			</div>
		</footer>
	</main>
</Layout>
